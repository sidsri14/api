# Database (SQLite default for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"

# Authentication
JWT_SECRET="replace-with-a-long-random-secret"
COOKIE_SECRET="replace-with-a-long-random-secret"

# Razorpay Configuration (Get these from Razorpay Dashboard > Settings > API Keys/Webhooks)
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"
RAZORPAY_WEBHOOK_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"

# Connectivity
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
NODE_ENV="development"
PORT=3000

# Frontend URL (For payment success callbacks)
FRONTEND_URL="http://localhost:5173"

# Email Configuration (Future proofing for production integration)
RESEND_API_KEY="re_XXXXXXX"
EMAIL_FROM="recovery@yourdomain.com"
