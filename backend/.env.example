PORT=3000

# 32-byte AES-256 key for encrypting Razorpay secrets at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If you change this, existing PaymentSources must be re-added.
ENCRYPTION_KEY=<64-char hex string>

NODE_ENV=development

DATABASE_URL="file:./prisma/dev.db"

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<64-char hex string>

ALLOWED_ORIGINS=http://localhost:5173

# Optional: used as the callback_url in generated payment links
# FRONTEND_URL=http://localhost:5173

# Razorpay credentials — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
# Get webhook secret from Dashboard > Webhooks after creating a webhook
RAZORPAY_WEBHOOK_SECRET=xxxx

# Email (SMTP) — without these, emails are printed to console (dev mode)
# Gmail:     SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use an App Password)
# SendGrid:  SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=PayRecover <noreply@yourdomain.com>
